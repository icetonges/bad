# ============================================================
# fedAnalyst — Environment Variables
# Copy to .env.local for development. Set in Vercel for production.
# ============================================================

# --- Anthropic (AI agent) ---
# Required. Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-opus-4-7

# --- Supabase (database, vector store, auth, storage) ---
# Required. Get from https://supabase.com project settings
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# --- Embeddings (choose one) ---
# Option A: Voyage AI (recommended for Anthropic shops)
VOYAGE_API_KEY=pa-xxxxx
EMBEDDING_MODEL=voyage-3-large
# Option B: OpenAI (alternative)
# OPENAI_API_KEY=sk-xxxxx
# EMBEDDING_MODEL=text-embedding-3-large

# --- Contact form email (choose one) ---
# Option A: Resend (recommended — single API key)
RESEND_API_KEY=re_xxxxx
CONTACT_TO_EMAIL=you@example.com
CONTACT_FROM_EMAIL=fedanalyst@yourdomain.com

# Option B: Gmail via Nodemailer (alternative — use app password, not OAuth for simplicity)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- MCP servers (optional, comma-separated) ---
# Each MCP server is a URL or stdio command. See docs/MCP_SETUP.md
MCP_SERVERS=

# --- Vercel / deployment ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
