# ============================================================
# fedAnalyst — Environment Variables
# Copy to .env.local for development. Set in Vercel for production.
# ============================================================

# --- AI providers (waterfall: Gemini → Groq 70B → Groq 8B → Gemini Flash) ---
# Required — primary provider. Get free at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Required — fallback provider. Get free at https://console.groq.com/keys
GROQ_API_KEY=

# --- Neon Postgres (database + pgvector) ---
# These match your existing aimlgov.vercel.app project — reuse the same values.
DATABASE_URL=postgres://user:pass@host.neon.tech/db?sslmode=require
DATABASE_URL_UNPOOLED=postgres://user:pass@host-unpooled.neon.tech/db?sslmode=require
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGPASSWORD=
PGDATABASE=

# --- Vercel Blob (uploaded file storage) ---
# Create in Vercel dashboard → Storage → Blob. Token starts with vercel_blob_rw_
BLOB_READ_WRITE_TOKEN=

# --- Contact form (Gmail SMTP via Nodemailer) ---
# GMAIL_USER is the sending Gmail account.
# GMAIL_APP_PASSWORD is a 16-character app password — NOT your Gmail login password.
# Create one at: https://myaccount.google.com/apppasswords
# (Requires 2FA enabled on the Gmail account.)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=you@gmail.com

# --- MCP servers (optional, comma-separated commands) ---
MCP_SERVERS=

# --- Site URL (used by python_analysis tool to call /api/analyze) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
